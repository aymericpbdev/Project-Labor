generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───

enum Role {
  Agriculteur
  Saisonnier
  Public
}

enum StatutAnnonce {
  Ouverte
  Fermée
  Archivée
  Brouillon
}

enum StatutCandidature {
  En_Attente
  Acceptée
  Refusée
}

// ─── User ───

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role
  prenom    String
  nom       String
  telephone String

  // Relations 
  exploitation Exploitation?
  saisonnier   Saisonnier?
  annonces Annonce[] @relation("AnnoncesAgriculteur")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Exploitation ───

model Exploitation {
  id     String @id @default(uuid())

  // Relation 1-à-1 avec User
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  nomExploitation String
  siret           String

  // Une exploitation publie plusieurs annonces
  annonces Annonce[]
}

// ─── Saisonnier ───

model Saisonnier {
  id String @id @default(uuid())

  // Relation 1-à-1 avec User
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  // Un saisonnier a plusieurs documents et candidatures
  documents    Document[]
  candidatures Candidature[]
}

// ─── Document ───

model Document {
  id String @id @default(uuid())

  // Relation plusieurs-à-1 avec Saisonnier
  saisonnierId String
  saisonnier   Saisonnier @relation(fields: [saisonnierId], references: [id])

  label String
  cvUrl String?
}

// ─── Annonce ───

model Annonce {
  id String @id @default(uuid())

  // Relation Exploitation
  exploitationId String
  exploitation   Exploitation @relation(fields: [exploitationId], references: [id])

  agriculteurId String
  agriculteur   User @relation("AnnoncesAgriculteur", fields: [agriculteurId], references: [id])

  titre          String
  statut         StatutAnnonce @default(Ouverte)
  nombreDePostes Int
  hebergement    String
  remuneration   Folat
  competences    String
  domaine        String
  type           String
  dates          String
  date_debut     DateTime
  date_fin       DateTime

  // Une annonce reçoit plusieurs candidatures
  candidatures Candidature[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Candidature ───

model Candidature {
  id String @id @default(uuid())

  // Relation vers Annonce
  annonceId String
  annonce   Annonce @relation(fields: [annonceId], references: [id])

  // Relation vers Saisonnier
  saisonnierId String
  saisonnier   Saisonnier @relation(fields: [saisonnierId], references: [id])

  message String
  statut  StatutCandidature @default(En_Attente)

  // Fil de messages liés à cette candidature
  messages Message[]

  createdAt DateTime @default(now())

  @@unique([annonceId, saisonnierId])
}

// ─── Message ───

model Message {
  id String @id @default(uuid())

  // Relation vers Candidature
  candidatureId String
  candidature   Candidature @relation(fields: [candidatureId], references: [id])

  msg       String
  createdAt DateTime @default(now())
}